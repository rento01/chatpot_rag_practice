# ──────────────────────────────────────────────
# DB
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://chat:chat@localhost:5432/chat

# ──────────────────────────────────────────────
# CORS
# 許可オリジン（カンマ区切り、フロントエンドのオリジンを列挙）
# ──────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────
# LLM プロバイダ
#   ollama  : ローカル前提。初期状態はこちら
#   bedrock : AWS 移行時 (Phase 7) で有効化
# ──────────────────────────────────────────────
LLM_PROVIDER=ollama

# Ollama
#
# OLLAMA_URL の使い分け (詳細は SETUP_GUIDE.md):
#   - ホスト OS で `ollama serve` を起動して使う場合 (デフォルト / 推奨):
#       http://host.docker.internal:11434
#   - docker compose の ollama サービスを使う場合 (`make up-d` 利用時):
#       http://ollama:11434
#   - uvicorn などで backend を直接ホスト OS で起動する場合:
#       http://localhost:11434
#
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
EMBEDDING_MODEL=nomic-embed-text

# Bedrock（Phase 7 で利用）
BEDROCK_REGION=
BEDROCK_CHAT_MODEL_ID=
BEDROCK_EMBED_MODEL_ID=

# ──────────────────────────────────────────────
# Vector DB プロバイダ
#   chroma     : ローカル前提。初期状態はこちら
#   opensearch : AWS 移行時 (Phase 7) で有効化
# ──────────────────────────────────────────────
VECTOR_DB_PROVIDER=chroma

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# OpenSearch（Phase 7 で利用）
OPENSEARCH_ENDPOINT=
OPENSEARCH_INDEX_PREFIX=rag-chat

# ──────────────────────────────────────────────
# 検索パラメータ（Phase 3-2 以降）
# ──────────────────────────────────────────────
SEARCH_TOP_K=5

# RRF（Reciprocal Rank Fusion）パラメータ（Phase 3-3 以降）
# k が大きいほど順位の影響が均一になる。デフォルト 60 は RRF の標準値
RRF_K=60

# ──────────────────────────────────────────────
# アップロード上限 (MB)
# ──────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ──────────────────────────────────────────────
# ログ
# ──────────────────────────────────────────────
LOG_LEVEL=INFO

# ──────────────────────────────────────────────
# Langfuse (任意 / Phase 4 で設定)
# キーが両方空ならトレースは no-op
# ──────────────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
